# CRM Flow24 — переменные окружения (шаблон)
# Скопируйте в .env или .env.local. Файлы .env* не коммитятся.

# Database (локально — совпадает с site/docker-compose.yml)
DATABASE_URL="postgresql://crmflow24:crmflow24_dev_password@localhost:5432/crmflow24_dev?schema=public"

# Admin seed (задайте перед npm run db:seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-before-use"

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# STAGE: production | staging | development (robots, sitemap, RSS). Локально — development.
# STAGE="development"

# Production на VPS:
# STAGE="production"
# NEXT_PUBLIC_SITE_URL="https://crmflow24.ru"

# Auth/session (будущая admin-auth; сгенерируйте случайную строку)
AUTH_SECRET="replace-with-random-secret"

# Local uploads (медиа блога, dev)
UPLOADS_DIR="./public/uploads"
UPLOADS_PUBLIC_BASE_URL="/uploads"

# VK publishing (ручная публикация из админки; токен не коммитить)
VK_ACCESS_TOKEN=""
VK_GROUP_ID=""
VK_API_VERSION="5.199"
# VK_DRY_RUN !== "false" → dry-run (реальный wall.post не вызывается)
VK_DRY_RUN="true"

# Публичный URL сайта (production):
# NEXT_PUBLIC_SITE_URL=https://crmflow24.ru

# Входящий вебхук Bitrix24 (только сервер, без NEXT_PUBLIC_ — не попадает в клиентский бандл).
# Подставьте реальный URL из раздела «Разработчикам» портала, например:
# BITRIX_WEBHOOK_URL=https://pbweb.bitrix24.ru/rest/USER_ID/WEBHOOK_CODE/
BITRIX_WEBHOOK_URL=https://pbweb.bitrix24.ru/rest/USER_ID/WEBHOOK_CODE/
