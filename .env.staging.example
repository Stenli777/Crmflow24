# CRM Flow24 — staging (шаблон)
# Скопируйте на сервер: cp .env.staging.example .env
# Реальные секреты в git не коммитить.

# App
NODE_ENV="production"
STAGE="staging"
NEXT_PUBLIC_SITE_URL="https://stage.crmflow24.ru"
PORT="3001"

# Database (PostgreSQL на VPS или в Docker — см. docs/deploy/postgres-vps.md)
DATABASE_URL="postgresql://crmflow24_stage_user:CHANGE_ME@localhost:5432/crmflow24_stage?schema=public"

# Admin seed (только для первичного npm run db:seed; после создания admin можно сменить пароль в БД)
ADMIN_EMAIL="info@crmflow24.ru"
ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# Auth/session (стабильный между рестартами; openssl rand -base64 32)
AUTH_SECRET="CHANGE_ME_RANDOM_32_BYTES"

# Bitrix24 (если форма заявок использует вебхук)
BITRIX_WEBHOOK_URL="CHANGE_ME_IF_USED"

# Uploads (предпочтительно symlink на shared — см. docs/deploy/uploads-vps.md)
UPLOADS_DIR="./public/uploads"
UPLOADS_PUBLIC_BASE_URL="/uploads"

# Backup scripts (cron на VPS)
# BACKUP_DIR="/var/backups/crmflow24"
# RETENTION_DAYS="14"
